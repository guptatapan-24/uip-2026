# Environment Configuration Template
# Copy to .env and populate with actual values

# API Gateway
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=INFO

# JWT / Auth
JWT_SECRET_KEY=your-rs256-private-key-here
JWT_PUBLIC_KEY=your-rs256-public-key-here
JWT_ALGORITHM=RS256
JWT_EXPIRATION_HOURS=24

# Database
DATABASE_URL=postgresql+asyncpg://llm_user:password@postgres:5432/llm_firewall
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL_SECONDS=86400

# NVD API
NVD_API_KEY=your-nvd-api-key
NVD_BASE_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
NVD_REQUEST_TIMEOUT_SECONDS=30

# MITRE ATT&CK
ATTACK_API_URL=https://raw.githubusercontent.com/mitre/cti/master/enterprise-attack/
ATTACK_CACHE_DIR=/data/attack_cache
ATTACK_SYNC_INTERVAL_DAYS=30

# CISA KEV
KEV_API_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
KEV_CACHE_DIR=/data/kev_cache
KEV_SYNC_INTERVAL_DAYS=1

# FAISS
FAISS_INDEX_PATH=/data/faiss_indexes
FAISS_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Ollama / LLM
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral:7b
OLLAMA_TIMEOUT_SECONDS=2
OLLAMA_FALLBACK_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key-here

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Feature Flags
ENABLE_LLM_VERIFIER=true
ENABLE_SEMANTIC_VALIDATION=true
ENABLE_AUDIT_HASH_CHAIN=true
POLICY_PROFILE_NAME=default

# Security
CORS_ORIGINS=["http://localhost:3000", "https://soc.company.com"]
ALLOWED_ROLES=["SOC_ANALYST", "SOC_ADMIN", "SYSTEM"]
